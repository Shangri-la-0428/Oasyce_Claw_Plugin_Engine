# Oasyce 配置文件示例
# 复制此文件为 .env 并填入实际值

# === 基础配置 ===
# 数据账本目录（存放已注册资产的 JSON 凭证）
OASYCE_VAULT_DIR=~/Desktop/Oasyce_Claw_Plugin_Engine/genesis_vault

# 资产所有者名称
OASYCE_OWNER=Shangrila

# 默认标签（逗号分隔）
OASYCE_TAGS=Core,Genesis

# === 安全配置 ===
# HMAC-SHA256 签名私钥（生产环境请使用强随机密钥！）
OASYCE_SIGNING_KEY=DEFAULT_INSECURE_DEV_KEY_0x123

# 签名密钥标识符
OASYCE_SIGNING_KEY_ID=dev_key_001

# === 日志配置 ===
# 日志级别：DEBUG/INFO/WARNING/ERROR/CRITICAL
OASYCE_LOG_LEVEL=INFO

# 日志文件路径（可选，为空则只输出到控制台）
# OASYCE_LOG_FILE=~/.oasyce/oasyce.log

# === L2 定价配置 ===
# Bonding Curve 初始价格（OAS 代币）
OASYCE_INITIAL_PRICE=10.0

# 价格滑点系数（0.01 = 1%）
OASYCE_SLIPPAGE=0.01

# === 高级配置 ===
# 哈希算法（默认 sha256）
OASYCE_HASH_ALGO=sha256

# 分块大小（字节，用于大文件流式哈希）
OASYCE_CHUNK_SIZE=65536

# === 存储配置 ===
# 存储类型：local | ipfs
OASYCE_STORAGE_TYPE=local

# 本地存储目录（OASYCE_STORAGE_TYPE=local 时使用）
OASYCE_STORAGE_DIR=~/.oasyce/storage

# IPFS 节点主机（OASYCE_STORAGE_TYPE=ipfs 时使用）
# OASYCE_IPFS_HOST=127.0.0.1

# IPFS 节点端口
# OASYCE_IPFS_PORT=5001

# === AI 模型配置 ===
# AigoCode API Key（⚠️ 生产环境请妥善保管）
AIGOCODE_API_KEY=your-api-key-here

# AigoCode API Base URL
AIGOCODE_BASE_URL=https://api.aigocode.com/v1

# AigoCode 默认模型
AIGOCODE_MODEL=aigocode/claude-opus-4-6
